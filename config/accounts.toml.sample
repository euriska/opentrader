# ── Alpaca accounts ───────────────────────────────────────────────────────────

[[accounts]]
id             = "${ALPACA_PAPER_ACCOUNT_ID}"
broker         = "alpaca"
mode           = "paper"
label          = "alpaca-paper"
enabled        = true
strategy_tags  = ["equity", "etf", "options"]
max_position_usd = 10000
notes          = "Alpaca paper trading — uses ALPACA_API_KEY_ID + ALPACA_API_SECRET_KEY"

