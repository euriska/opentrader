# =============================================================================
# OpenTrader — Account Registry
# Each account has: id, broker, mode, label, enabled, strategy_tags
# strategy_tags controls which strategies can trade this account
# =============================================================================

# ── Tradier accounts ──────────────────────────────────────────────────────────

[[accounts]]
id             = "${TRADIER_SANDBOX_ACCOUNT_NUMBER}"
broker         = "tradier"
mode           = "sandbox"
label          = "tradier-sandbox"
enabled        = true
strategy_tags  = ["equity", "etf", "options"]   # all strategies allowed in sandbox
max_position_usd = 10000
notes          = "Tradier paper trading — full API mirror of live"

[[accounts]]
id             = "${TRADIER_PROD_ACCOUNT_1}"
broker         = "tradier"
mode           = "live"
label          = "tradier-prod-1"
enabled        = true
strategy_tags  = ["equity", "etf"]
max_position_usd = 1000
notes          = "Production account 1"

[[accounts]]
id             = "${TRADIER_PROD_ACCOUNT_2}"
broker         = "tradier"
mode           = "live"
label          = "tradier-prod-2"
enabled        = true
strategy_tags  = ["equity", "etf"]
max_position_usd = 2000
notes          = "Production account 2"

[[accounts]]
id             = "${TRADIER_PROD_ACCOUNT_3}"
broker         = "tradier"
mode           = "live"
label          = "tradier-prod-3"
enabled        = true
strategy_tags  = ["equity"]
max_position_usd = 1000
notes          = "Production account 3 (IRA)"

[[accounts]]
id             = "${TRADIER_PROD_ACCOUNT_4}"
broker         = "tradier"
mode           = "live"
label          = "tradier-prod-4"
enabled        = true
strategy_tags  = ["equity"]
max_position_usd = 1000
notes          = "Production account 4 (IRA)"

